    "import inspect\n",
    "import jax\n",
    "import jax.numpy as jnp\n",
    "from h5loader import DataProvider\n",
    "from utils import load_json\n",
    "\n",
    "def _make_dataprovider(cls, **kwargs):\n",
    "    sig = inspect.signature(cls.__init__)\n",
    "    accepted = set(sig.parameters.keys()); accepted.discard(\"self\")\n",
    "    filtered = {k: v for k, v in kwargs.items() if k in accepted}\n",
    "    return cls(**filtered)\n",
    "\n",
    "test_file = \"/home/taeyoungkim/CONTEXT_FLUX_NO/data/cubic_no_source_test_100_100.hdf5\"\n",
    "cfg = load_json(\"train_config.json\")\n",
    "\n",
    "dp = _make_dataprovider(\n",
    "    DataProvider,\n",
    "    seed=123,\n",
    "    demo_num=20,\n",
    "    cond_len=100,\n",
    "    qoi_len=100,\n",
    "    batch_size=10000,\n",
    "    shuffle_buffer_size=1000,\n",
    "    file_names=[test_file],\n",
    "    k_dim=1,\n",
    "    v_dim=1,\n",
    "    config=cfg,\n",
    "    select=\"random\",\n",
    "    k_mode=\"naive\",\n",
    "    deterministic=True,\n",
    "    tau=0.005,\n",
    "    t_init_window=0.4,\n",
    "    pairs_per_operator=10000,\n",
    "    direction=\"forward\",\n",
    ")\n",
    "\n",
    "raws, equation, prompt, mask, query, query_mask, ground_truth,pde,ic,si  = dp.get_next_data(\n",
    "    decode_equation=True, list_size=0, return_raw=True\n",
    ")\n",
    "\n",
    "print(\"prompt:\", prompt.shape, \"query:\", query.shape, \"gt:\", ground_truth.shape, \"pde:\", pde.shape, \"ic:\", ic.shape, \"si:\", si.shape)"
   ]
