    "import haiku as hk\n",
    "import models\n",
    "\n",
    "# ckpt가 학습 때 쓴 하이퍼파라미터와 동일해야 함\n",
    "HIDDEN = 256\n",
    "HEADS = 8\n",
    "LAYERS = 6\n",
    "QOI_V_DIM = 1\n",
    "INITIALIZER = \"glorot_uniform\"\n",
    "\n",
    "def forward(prompt, mask, query):\n",
    "    net = models.SolverModel(\n",
    "        q_size=HIDDEN,\n",
    "        kv_size=HIDDEN,\n",
    "        qoi_v_size=QOI_V_DIM,\n",
    "        QK_size=HIDDEN,\n",
    "        V_size=HIDDEN,\n",
    "        num_heads=HEADS,\n",
    "        num_layers=LAYERS,\n",
    "        initializer=INITIALIZER,\n",
    "    )\n",
    "    return net(prompt, mask, query)\n",
    "\n",
    "f = hk.transform(forward)\n",
    "\n",
    "@jax.jit\n",
    "def apply_one(params, prompt, mask, query, seed=0):\n",
    "    rng = jax.random.PRNGKey(seed)\n",
    "    return f.apply(params, rng, prompt, mask, query)"
   ]
