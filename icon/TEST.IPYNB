    "import numpy as np\n",
    "\n",
    "# dp는 \"새로 만든\" DataProvider여야 함 (중요!)\n",
    "# dp = DataProvider(seed=123, ...)\n",
    "\n",
    "rng = np.random.default_rng(dp.seed)  # dp.get_next_data()가 쓰는 것과 같은 초기화\n",
    "\n",
    "# 1) directions (direction=\"both\"일 때 shuffle로 RNG 소비)\n",
    "dirs = dp._sample_direction_for_batch()  # 내부에서 dp.rng를 쓰지만, 아래는 동일 재현을 위해 직접 구현해도 됨\n",
    "# ---- dp._sample_direction_for_batch를 그대로 재현하려면 이렇게 ----\n",
    "# if dp.direction == \"both\":\n",
    "#     half = dp.batch_size // 2\n",
    "#     dirs = [\"forward\"] * half + [\"backward\"] * (dp.batch_size - half)\n",
    "#     rng.shuffle(dirs)\n",
    "# else:\n",
    "#     dirs = [dp.direction] * dp.batch_size\n",
    "\n",
    "# 2) 배치 루프에서 pde_idx -> ic_idx -> si 순서로 RNG 소비\n",
    "out = []\n",
    "for bi in range(dp.batch_size):\n",
    "    pde_idx = int(rng.integers(0, dp.bank.n_total_pde))\n",
    "\n",
    "    # locate -> n_ic, len(start_idx), stride를 \"실제 meta\"에서 가져오기\n",
    "    fi, pi = dp.bank._locate(pde_idx)\n",
    "    m = dp.bank.meta[fi]\n",
    "    start_idx = m[\"start_idx\"]\n",
    "    stride = int(m[\"stride\"])\n",
    "    ds_values = m[\"ds_values\"]\n",
    "    u_shape = ds_values.shape\n",
    "    n_ic = u_shape[1]  # (n_pde, n_ic, n_t, ...)\n",
    "\n",
    "    n_pairs = dp.demo_num + 1\n",
    "    ic_idx = rng.integers(0, n_ic, size=(n_pairs,), endpoint=False)\n",
    "\n",
    "    if dp.select == \"sequential\":\n",
    "        startnum = rng.integers(0, len(start_idx) - 200)\n",
    "        si = np.arange(startnum, startnum + 10*n_pairs, 10)\n",
    "    else:\n",
    "        si = rng.integers(0, len(start_idx), size=(n_pairs,), endpoint=False)\n",
    "\n",
    "    t0 = start_idx[si]\n",
    "    t1 = t0 + stride\n",
    "\n",
    "    out.append((dirs[bi], pde_idx, ic_idx.copy(), si.copy(), t0.copy(), t1.copy()))\n",
    "\n",
    "print(out[0][0], out[0][1], out[0][2][:5], out[0][3][:5])"
   ]
