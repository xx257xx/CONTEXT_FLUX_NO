   "source": [
    "import h5py\n",
    "import numpy as np\n",
    "\n",
    "path = \"/home/taeyoungkim/CONTEXT_FLUX_NO/data/cubic_no_source_test_100_100.hdf5\"\n",
    "pred = np.array(loadded2)  # (2000, ?, 20, 100) 같은 형태라고 가정\n",
    "\n",
    "final_l2 = []\n",
    "total_l2 = []\n",
    "final_linf = []\n",
    "total_linf = []\n",
    "\n",
    "eps = 1e-12\n",
    "\n",
    "with h5py.File(path, \"r\") as f:\n",
    "    values = f[\"values\"]\n",
    "\n",
    "    for i in range(2003):\n",
    "        p  = int(pdess[0, i])\n",
    "        ic = int(icss[0, i])\n",
    "        s0 = int(siss[0, i])\n",
    "\n",
    "        # 20-step time indices (너 정의 그대로)\n",
    "        s_list = np.array([s0 + 10*(j+1) for j in range(20)], dtype=np.int64)\n",
    "\n",
    "        # GT: (20, Nx)\n",
    "        u_gt = values[p, ic, s_list, 0, :]  # (20, 100)\n",
    "\n",
    "        # Pred: (20, Nx)\n",
    "        u_pr = pred[i % 2000, int(i/2000)].squeeze()\n",
    "        if u_pr.shape == (100, 20):   # 혹시 축이 뒤집혀 있으면 자동 보정\n",
    "            u_pr = u_pr.T\n",
    "\n",
    "        # ---------- FINAL (last step) ----------\n",
    "        err_f = u_pr[-1] - u_gt[-1]  # (Nx,)\n",
    "        final_l2.append(np.linalg.norm(err_f) / (np.linalg.norm(u_gt[-1]) + eps))\n",
    "        final_linf.append(np.max(np.abs(err_f)) / (np.max(np.abs(u_gt[-1])) + eps))\n",
    "\n",
    "        # ---------- TOTAL (all steps, time×space) ----------\n",
    "        err_all = (u_pr - u_gt).reshape(-1)\n",
    "        gt_all  = u_gt.reshape(-1)\n",
    "        total_l2.append(np.linalg.norm(err_all) / (np.linalg.norm(gt_all) + eps))\n",
    "        total_linf.append(np.max(np.abs(err_all)) / (np.max(np.abs(gt_all)) + eps))\n",
    "\n",
    "final_l2 = np.array(final_l2)\n",
    "total_l2 = np.array(total_l2)\n",
    "final_linf = np.array(final_linf)\n",
    "total_linf = np.array(total_linf)\n",
    "\n",
    "print(\"final_l2:   \", final_l2.shape, \"mean=\", final_l2.mean(), \"std=\", final_l2.std())\n",
    "print(\"total_l2:   \", total_l2.shape, \"mean=\", total_l2.mean(), \"std=\", total_l2.std() )\n",
    "print(\"final_linf: \", final_linf.shape, \"mean=\", final_linf.mean(), \"std=\", final_linf.std())\n",
    "print(\"total_linf: \", total_linf.shape, \"mean=\", total_linf.mean(), \"std=\", total_linf.std())"
   ]
